{
  "name": "treesize",
  "version": "4.0.0",
  "description": "磁盘空间分析工具",
  "main": "dist/main/main/main.js",
  "scripts": {
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build --config src/renderer/vite.config.ts",
    "start": "electron .",
    "test:scanner": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.js --testPathPattern=scanner",
    "make:win": "npm run build && npx electron-builder --win zip --x64"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}

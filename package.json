{
  "name": "treesize",
  "version": "3.0.0",
  "description": "磁盘空间分析工具 — 可视化磁盘使用、定位大文件、检测重复、AI 智能清理",
  "main": "dist/main/main/main.js",
  "author": "kemo2046",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite --config src/renderer/vite.config.ts",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build --config src/renderer/vite.config.ts",
    "start": "electron .",
    "dev:electron": "NODE_ENV=development electron .",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "make:win": "npm run build && electron-forge make --platform win32",
    "make:mac": "npm run build && electron-forge make --platform darwin",
    "make:linux": "npm run build && electron-forge make --platform linux"
  },
  "dependencies": {},
  "devDependencies": {
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-squirrel": "^7.0.0",
    "@electron-forge/maker-zip": "^7.0.0",
    "@electron-forge/maker-deb": "^7.0.0",
    "@electron-forge/maker-dmg": "^7.0.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
